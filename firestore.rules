rules_version = '2';

// Dilema 10 Tahanan — casual no-login minigame.
// Fully open: anyone with the project config can read/write game data.
// This is intentional for a short-lived classroom game and matches the rule set
// in the Firebase console. Deploy it to the "experiment" database (see
// firebase.json). For anything beyond a throwaway game, tighten these.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
